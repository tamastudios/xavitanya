{
  "buildCommand": "npm install --prefix obraslink/obraslink && npm run build --prefix obraslink/obraslink",
  "outputDirectory": "obraslink/obraslink/dist",
  "rewrites": [
    { "source": "/((?!assets/|sw\\.js|workbox-|manifest\\.webmanifest|registerSW\\.js|pwa-|apple-touch-icon).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
